# API keys for gateway (comma-separated). If empty, no auth required (dev only).
API_KEYS=sk-your-key-1,sk-your-key-2

# Optional: if vLLM is started with --api-key, set it here so the gateway can call vLLM.
VLLM_API_KEY=

# Rate limit: requests per minute per API key.
RATE_LIMIT_RPM=60

# Max concurrent requests to vLLM (gateway semaphore).
MAX_CONCURRENT_REQUESTS=32

# vLLM model (used by docker-compose for the vllm service).
VLLM_MODEL=microsoft/Phi-3-mini-4k-instruct

# Hugging Face token for gated models (optional).
# HF_TOKEN=
